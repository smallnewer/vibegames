{
  "name": "blocky-wilds-rpg",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "assets:build:animations": "/Applications/Blender.app/Contents/MacOS/Blender --background --factory-startup --python scripts/blender/build-ual-block-rig.py -- public/game-assets/action-lab/quaternius-ual1-standard.glb /tmp/pixel-rpg-ual-block-combat-base.glb production && node scripts/retarget-humanoid-animation.mjs /tmp/pixel-rpg-ual-block-combat-base.glb",
    "assets:build:rig-lab": "/Applications/Blender.app/Contents/MacOS/Blender --background --factory-startup --python scripts/blender/build-ual-block-rig.py -- public/game-assets/action-lab/quaternius-ual1-standard.glb public/game-assets/rig-lab/ual-block-rig.glb",
    "content:build": "node scripts/compile-dungeons.mjs && node scripts/compile-actor-visuals.mjs && node scripts/compile-balance.mjs && node scripts/compile-items.mjs && node scripts/compile-abilities.mjs",
    "prebuild": "npm run content:build",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "pretest:unit": "npm run content:build",
    "test:unit": "vitest --config vitest.config.ts run tests/game",
    "test:rpg": "vitest --config vitest.config.ts run tests/game",
    "test:performance-contract": "vitest --config vitest.config.ts run tests/game/performance",
    "balance:simulate": "node --import tsx scripts/simulate-balance.mjs",
    "assets:icons:slice": "node scripts/slice-icon-sheet.mjs",
    "assets:icons:validate": "node scripts/validate-icons.mjs",
    "test:icons": "node --test tests/icon-manifest.test.mjs",
    "test:content": "node --test tests/content-compiler.test.mjs tests/actor-visual-compiler.test.mjs",
    "test": "npm run test:content && npm run test:icons && npm run test:unit && npm run build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@babylonjs/addons": "^9.16.1",
    "@babylonjs/core": "^9.16.1",
    "@babylonjs/havok": "^1.3.13",
    "@babylonjs/loaders": "^9.16.1",
    "@recast-navigation/core": "^0.43.1",
    "@recast-navigation/generators": "^0.43.1",
    "@recast-navigation/wasm": "^0.43.1",
    "@types/three": "^0.185.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "^8.20.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
