{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blocky-wilds.local/schema/items.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bases", "affixes", "uniques"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "bases": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/base" } },
    "affixes": { "type": "array", "minItems": 1, "maxItems": 18, "items": { "$ref": "#/$defs/affix" } },
    "uniques": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/unique" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$", "maxLength": 100 },
    "statName": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$", "maxLength": 64 },
    "slot": { "enum": ["head", "chest", "wrists", "legs", "feet", "melee", "ranged"] },
    "base": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "slot", "iconFamily", "visual", "theme", "coreStat", "baseMin", "baseMax", "affixTags"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "slot": { "$ref": "#/$defs/slot" },
        "iconFamily": { "$ref": "#/$defs/id" }, "visual": { "$ref": "#/$defs/id" },
        "theme": { "$ref": "#/$defs/id" }, "coreStat": { "$ref": "#/$defs/statName" },
        "baseMin": { "type": "number", "minimum": 0 }, "baseMax": { "type": "number", "minimum": 0 },
        "affixTags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    },
    "affix": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "group", "kind", "slots", "stat", "core", "tiers"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "group": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["prefix", "suffix"] },
        "slots": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/slot" } },
        "stat": { "$ref": "#/$defs/statName" }, "core": { "type": "boolean" },
        "tiers": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "$ref": "#/$defs/tier" } }
      }
    },
    "tier": {
      "type": "object", "additionalProperties": false, "required": ["minFactor", "maxFactor"],
      "properties": { "minFactor": { "type": "number" }, "maxFactor": { "type": "number" } }
    },
    "unique": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "base", "dungeon", "affixes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "base": { "$ref": "#/$defs/id" },
        "dungeon": { "$ref": "#/$defs/id" },
        "affixes": { "type": "array", "minItems": 4, "maxItems": 5, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    }
  }
}
